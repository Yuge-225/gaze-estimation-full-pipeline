diff --git a/node_modules/react-native-vision-camera/android/build/headers/visioncamera/react-native-vision-camera/PassThroughShader.h b/node_modules/react-native-vision-camera/android/build/headers/visioncamera/react-native-vision-camera/PassThroughShader.h
